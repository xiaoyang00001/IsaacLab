# G1 dual-robot network configuration.
#
# Topology:
#   Ubuntu robot 1 sender: 192.168.10.230
#   Ubuntu robot 2 sender: 192.168.10.231
#   Windows robot 1 Isaac Lab: 192.168.10.46
#   Windows robot 2 Isaac Lab: 192.168.10.46
#
# Format is KEY=value so this file can be sourced by Bash and parsed by Python.

# ---------------------------------------------------------------------------
# Physical process IPs.
# Keep IP addresses here. Body/root streams connect to the Ubuntu sender IPs;
# gripper sync connects to the Windows Isaac Lab IPs.
# If both Isaac Lab processes run on one Windows host, keep both Windows IPs
# the same. If they run on two Windows hosts, change robot 2 accordingly.
# ---------------------------------------------------------------------------
UBUNTU_ROBOT_1_SENDER_IP=192.168.10.231
UBUNTU_ROBOT_2_SENDER_IP=192.168.10.230
WINDOWS_ROBOT_1_ISAACLAB_IP=192.168.10.46
WINDOWS_ROBOT_2_ISAACLAB_IP=192.168.10.46

# ---------------------------------------------------------------------------
# Local Isaac Lab role.
# Set ISAACLAB_LOCAL_ROBOT_ID=1 in the robot-1 Isaac Lab process and =2 in
# the robot-2 process. Each process can use its own copy of this file or
# override ISAACLAB_G1_NETWORK_CONFIG.
# ---------------------------------------------------------------------------
ISAACLAB_LOCAL_ROBOT_ID=2

# ---------------------------------------------------------------------------
# Windows Isaac Lab receiver settings.
# ---------------------------------------------------------------------------
ISAACLAB_G1_TRANSPORT=zmq
ISAACLAB_G1_VIEWER_SOURCE=zmq

ISAACLAB_G1_1_ZMQ_PORT=5557
ISAACLAB_G1_1_ZMQ_TOPIC=g1_1_debug
ISAACLAB_G1_1_ROOT_ZMQ_PORT=5558
ISAACLAB_G1_1_ROOT_ZMQ_TOPIC=g1_1_root

ISAACLAB_G1_2_ZMQ_PORT=5567
ISAACLAB_G1_2_ZMQ_TOPIC=g1_2_debug
ISAACLAB_G1_2_ROOT_ZMQ_PORT=5568
ISAACLAB_G1_2_ROOT_ZMQ_TOPIC=g1_2_root

ISAACLAB_G1_1_GRIPPER_ZMQ_PORT=5571
ISAACLAB_G1_1_GRIPPER_ZMQ_TOPIC=g1_1_gripper
ISAACLAB_G1_2_GRIPPER_ZMQ_PORT=5572
ISAACLAB_G1_2_GRIPPER_ZMQ_TOPIC=g1_2_gripper
ISAACLAB_G1_GRIPPER_TIMEOUT_S=0.5

# UDP fallback.
ISAACLAB_G1_UDP_BIND_HOST=0.0.0.0
ISAACLAB_G1_UDP_PORT=5557
ISAACLAB_G1_UDP_TOPIC=g1_debug
ISAACLAB_G1_UDP_RCVBUF=262144
ISAACLAB_G1_ROOT_UDP_BIND_HOST=0.0.0.0
ISAACLAB_G1_ROOT_UDP_PORT=5558
ISAACLAB_G1_ROOT_UDP_TOPIC=g1_root
ISAACLAB_G1_ROOT_UDP_RCVBUF=262144

# ---------------------------------------------------------------------------
# Ubuntu sender values are kept here for reference.
# Isaac Lab does not send these packets, but keeping both sides in one file
# makes IP changes easier to audit.
# ---------------------------------------------------------------------------
G1_LOCAL_ROBOT_ID=1
G1_OUTPUT_TYPE=zmq
G1_1_ZMQ_OUT_PORT=5557
G1_1_ZMQ_OUT_TOPIC=g1_1_debug
G1_2_ZMQ_OUT_PORT=5567
G1_2_ZMQ_OUT_TOPIC=g1_2_debug
G1_ZMQ_OUT_PORT=5557
G1_ZMQ_OUT_TOPIC=g1_debug
G1_1_UDP_OUT_BIND_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
G1_1_UDP_OUT_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
G1_1_UDP_OUT_PORT=5557
G1_1_UDP_OUT_TOPIC=g1_1_debug
G1_2_UDP_OUT_BIND_HOST=${UBUNTU_ROBOT_2_SENDER_IP}
G1_2_UDP_OUT_HOST=${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_2_UDP_OUT_PORT=5567
G1_2_UDP_OUT_TOPIC=g1_2_debug
G1_UDP_OUT_BIND_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
G1_UDP_OUT_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
G1_UDP_OUT_PORT=5557
G1_UDP_OUT_TOPIC=g1_debug
G1_1_ROOT_ZMQ_PORT=5558
G1_1_ROOT_ZMQ_TOPIC=g1_1_root
G1_1_ROOT_ZMQ_ENABLE=1
G1_2_ROOT_ZMQ_PORT=5568
G1_2_ROOT_ZMQ_TOPIC=g1_2_root
G1_2_ROOT_ZMQ_ENABLE=1
G1_ROOT_ZMQ_PORT=5558
G1_ROOT_ZMQ_TOPIC=g1_root
G1_ROOT_ZMQ_ENABLE=1
G1_1_ROOT_UDP_BIND_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
G1_1_ROOT_UDP_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
G1_1_ROOT_UDP_PORT=5558
G1_1_ROOT_UDP_TOPIC=g1_1_root
G1_1_ROOT_UDP_ENABLE=1
G1_2_ROOT_UDP_BIND_HOST=${UBUNTU_ROBOT_2_SENDER_IP}
G1_2_ROOT_UDP_HOST=${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_2_ROOT_UDP_PORT=5568
G1_2_ROOT_UDP_TOPIC=g1_2_root
G1_2_ROOT_UDP_ENABLE=1
G1_ROOT_UDP_BIND_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
G1_ROOT_UDP_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
G1_ROOT_UDP_PORT=5558
G1_ROOT_UDP_TOPIC=g1_root
G1_ROOT_UDP_ENABLE=1
