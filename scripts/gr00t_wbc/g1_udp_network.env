# G1 dual-robot network configuration.
#
# Topology:
#   Ubuntu robot 1 sender: 192.168.10.230
#   Ubuntu robot 2 sender: 192.168.10.231
#   Windows robot 1 Isaac Lab: 192.168.10.46
#   Windows robot 2 Isaac Lab: 192.168.10.46
#
# Format is KEY=value so this file can be sourced by Bash and parsed by Python.

# ---------------------------------------------------------------------------
# Physical process IPs.
# Keep IP addresses here. Body/root streams connect to the Ubuntu sender IPs;
# gripper sync connects to the Windows Isaac Lab IPs.
# If both Isaac Lab processes run on one Windows host, keep both Windows IPs
# the same. If they run on two Windows hosts, change robot 2 accordingly.
# ---------------------------------------------------------------------------
UBUNTU_ROBOT_1_SENDER_IP=192.168.10.230
UBUNTU_ROBOT_2_SENDER_IP=192.168.10.230
WINDOWS_ROBOT_1_ISAACLAB_IP=192.168.10.46
WINDOWS_ROBOT_2_ISAACLAB_IP=192.168.10.46
GR00T_WBC_ROOT=F:/ISAACWholeBody/GR00T-WholeBodyControl

# ---------------------------------------------------------------------------
# Local Isaac Lab role.
# Set ISAACLAB_LOCAL_ROBOT_ID=1 in the robot-1 Isaac Lab process and =2 in
# the robot-2 process.
# ---------------------------------------------------------------------------
ISAACLAB_LOCAL_ROBOT_ID=1

# ---------------------------------------------------------------------------
# Windows Isaac Lab receiver settings.
# ---------------------------------------------------------------------------
ISAACLAB_G1_TRANSPORT=udp
ISAACLAB_G1_VIEWER_SOURCE=udp

ISAACLAB_G1_1_ZMQ_PORT=5557
ISAACLAB_G1_1_ZMQ_TOPIC=g1_debug
ISAACLAB_G1_1_ZMQ_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
ISAACLAB_G1_1_ROOT_ZMQ_PORT=5558
ISAACLAB_G1_1_ROOT_ZMQ_TOPIC=g1_root
ISAACLAB_G1_1_ROOT_ZMQ_HOST=${UBUNTU_ROBOT_1_SENDER_IP}

ISAACLAB_G1_2_ZMQ_PORT=5567
ISAACLAB_G1_2_ZMQ_TOPIC=g1_2_debug
ISAACLAB_G1_2_ZMQ_HOST=${UBUNTU_ROBOT_2_SENDER_IP}
ISAACLAB_G1_2_ROOT_ZMQ_PORT=5568
ISAACLAB_G1_2_rROOT_ZMQ_TOPIC=g1_2_root
ISAACLAB_G1_2_ROOT_ZMQ_HOST=${UBUNTU_ROBOT_2_SENDER_IP}

ISAACLAB_G1_1_GRIPPER_ZMQ_PORT=5571
ISAACLAB_G1_1_GRIPPER_ZMQ_TOPIC=g1_1_gripper
ISAACLAB_G1_1_GRIPPER_ZMQ_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
ISAACLAB_G1_2_GRIPPER_ZMQ_PORT=5572
ISAACLAB_G1_2_GRIPPER_ZMQ_TOPIC=g1_2_gripper
ISAACLAB_G1_2_GRIPPER_ZMQ_HOST=${WINDOWS_ROBOT_2_ISAACLAB_IP}
ISAACLAB_G1_GRIPPER_TIMEOUT_S=0.5

# ---------------------------------------------------------------------------
# Windows Isaac Lab physical tracking behavior.
#
# Current stable dual-robot default:
#   - mirror: hard-sync root + 29-DoF body joints from MuJoCo. This keeps
#     MuJoCo walking stable in Isaac Lab and avoids root-only foot mismatch.
#     BODY_STATE_WRITE_JOINT_NAMES narrows the hard-sync to lower-body/waist
#     joints; shoulder/elbow/wrist joints still receive mirrored targets but are
#     not written directly to PhysX state.
#   - hands/gripper stay as actuator targets by default so grasp/contact tuning
#     still happens in PhysX.
#
# Experimental modes for later tuning:
#   - hybrid: hard-sync root, drive body joints through actuator targets.
#   - physics: leave root to PhysX, drive body joints through actuator targets.
#   - custom: honor WRITE_ROOT_STATE/WRITE_BODY_JOINT_STATE directly.
# These require an Isaac Lab balance/locomotion controller before they can walk
# reliably, so do not use them for the current walking mirror baseline.
#
# Generic ISAACLAB_G1_* values apply to both robots. To tune one robot
# independently, define or edit an ID-scoped override below.
# ---------------------------------------------------------------------------
ISAACLAB_G1_LOCOMOTION_SYNC_MODE=mirror
ISAACLAB_G1_JOINT_ORDER=mujoco
ISAACLAB_G1_POSE_SOURCE=auto
ISAACLAB_G1_STATE_WRITE_POSE_SOURCE=measured
# Arms are target-only so PhysX contacts remain active, but their targets must
# follow the measured q/dq pair. GR00T last_action is a low-level PD command and
# can differ from the measured shoulder/elbow pose by several tenths of a radian.
ISAACLAB_G1_TARGET_ONLY_POSE_SOURCE=measured
ISAACLAB_G1_HAND_POSE_SOURCE=target
ISAACLAB_G1_ROOT_MOTION_MODE=source
ISAACLAB_G1_ROOT_ZMQ_REQUIRED=0
ISAACLAB_G1_ROOT_POSITION_MODE=relative
ISAACLAB_G1_WRITE_ROOT_STATE=1
ISAACLAB_G1_WRITE_BODY_JOINT_STATE=1
ISAACLAB_G1_BODY_STATE_WRITE_JOINT_NAMES=.*_hip_.*_joint,.*_knee_joint,.*_ankle_.*_joint,waist_.*_joint
ISAACLAB_G1_WRITE_HAND_JOINT_STATE=0
ISAACLAB_G1_USE_SOURCE_JOINT_VELOCITY=1
ISAACLAB_G1_MIRROR_HANDS=1
ISAACLAB_G1_CONTROLLER_GRIPPER_ENABLED=0
ISAACLAB_G1_GROUND_LOCK=0
ISAACLAB_G1_HOLD_DEFAULT_UNTIL_FIRST_PACKET=1
ISAACLAB_G1_NO_PACKET_DEBUG_INTERVAL_S=1.0
ISAACLAB_G1_USE_USD_RIGID_PROPS=1
ISAACLAB_G1_BODY_JOINT_TARGET_MAX_DELTA=0.20
ISAACLAB_G1_ZERO_TARGET_ONLY_BODY_VELOCITY=0
ISAACLAB_G1_ZERO_TARGET_ONLY_HAND_VELOCITY=1
ISAACLAB_G1_BODY_JOINT_TARGET_SCALE_OVERRIDES=
ISAACLAB_G1_HAND_JOINT_TARGET_MAX_DELTA=0.08

# Arm/hand actuator tuning for physical grasping. Source joint velocity is kept
# as the velocity target so damping tracks motion instead of opposing it.
# Lower-body/root walking mirror is still handled separately by the body state
# write whitelist above.
ISAACLAB_G1_ARM_EFFORT_LIMIT=60.0
ISAACLAB_G1_ARM_VELOCITY_LIMIT=12.0
ISAACLAB_G1_ARM_STIFFNESS=700.0
ISAACLAB_G1_ARM_DAMPING=20.0
ISAACLAB_G1_ARM_ARMATURE=0.01
ISAACLAB_G1_HAND_EFFORT_LIMIT=24.0
ISAACLAB_G1_HAND_VELOCITY_LIMIT=5.0
ISAACLAB_G1_HAND_STIFFNESS=75.0
ISAACLAB_G1_HAND_DAMPING=9.0
ISAACLAB_G1_HAND_ARMATURE=0.05

ISAACLAB_G1_1_POSE_SOURCE=${ISAACLAB_G1_POSE_SOURCE}
ISAACLAB_G1_1_JOINT_ORDER=${ISAACLAB_G1_JOINT_ORDER}
ISAACLAB_G1_1_STATE_WRITE_POSE_SOURCE=${ISAACLAB_G1_STATE_WRITE_POSE_SOURCE}
ISAACLAB_G1_1_TARGET_ONLY_POSE_SOURCE=${ISAACLAB_G1_TARGET_ONLY_POSE_SOURCE}
ISAACLAB_G1_1_HAND_POSE_SOURCE=${ISAACLAB_G1_HAND_POSE_SOURCE}
ISAACLAB_G1_1_LOCOMOTION_SYNC_MODE=${ISAACLAB_G1_LOCOMOTION_SYNC_MODE}
ISAACLAB_G1_1_ROOT_MOTION_MODE=${ISAACLAB_G1_ROOT_MOTION_MODE}
ISAACLAB_G1_1_ROOT_ZMQ_REQUIRED=${ISAACLAB_G1_ROOT_ZMQ_REQUIRED}
ISAACLAB_G1_1_ROOT_POSITION_MODE=${ISAACLAB_G1_ROOT_POSITION_MODE}
ISAACLAB_G1_1_WRITE_ROOT_STATE=${ISAACLAB_G1_WRITE_ROOT_STATE}
ISAACLAB_G1_1_WRITE_BODY_JOINT_STATE=${ISAACLAB_G1_WRITE_BODY_JOINT_STATE}
ISAACLAB_G1_1_BODY_STATE_WRITE_JOINT_NAMES=${ISAACLAB_G1_BODY_STATE_WRITE_JOINT_NAMES}
ISAACLAB_G1_1_WRITE_HAND_JOINT_STATE=${ISAACLAB_G1_WRITE_HAND_JOINT_STATE}
ISAACLAB_G1_1_USE_SOURCE_JOINT_VELOCITY=${ISAACLAB_G1_USE_SOURCE_JOINT_VELOCITY}
ISAACLAB_G1_1_MIRROR_HANDS=${ISAACLAB_G1_MIRROR_HANDS}
ISAACLAB_G1_1_CONTROLLER_GRIPPER_ENABLED=${ISAACLAB_G1_CONTROLLER_GRIPPER_ENABLED}
ISAACLAB_G1_1_GROUND_LOCK=${ISAACLAB_G1_GROUND_LOCK}
ISAACLAB_G1_1_HOLD_DEFAULT_UNTIL_FIRST_PACKET=${ISAACLAB_G1_HOLD_DEFAULT_UNTIL_FIRST_PACKET}
ISAACLAB_G1_1_NO_PACKET_DEBUG_INTERVAL_S=${ISAACLAB_G1_NO_PACKET_DEBUG_INTERVAL_S}
ISAACLAB_G1_1_BODY_JOINT_TARGET_MAX_DELTA=${ISAACLAB_G1_BODY_JOINT_TARGET_MAX_DELTA}
ISAACLAB_G1_1_ZERO_TARGET_ONLY_BODY_VELOCITY=${ISAACLAB_G1_ZERO_TARGET_ONLY_BODY_VELOCITY}
ISAACLAB_G1_1_ZERO_TARGET_ONLY_HAND_VELOCITY=${ISAACLAB_G1_ZERO_TARGET_ONLY_HAND_VELOCITY}
ISAACLAB_G1_1_BODY_JOINT_TARGET_SCALE_OVERRIDES=${ISAACLAB_G1_BODY_JOINT_TARGET_SCALE_OVERRIDES}
ISAACLAB_G1_1_HAND_JOINT_TARGET_MAX_DELTA=${ISAACLAB_G1_HAND_JOINT_TARGET_MAX_DELTA}

ISAACLAB_G1_2_POSE_SOURCE=${ISAACLAB_G1_POSE_SOURCE}
ISAACLAB_G1_2_JOINT_ORDER=${ISAACLAB_G1_JOINT_ORDER}
ISAACLAB_G1_2_LOCOMOTION_SYNC_MODE=${ISAACLAB_G1_LOCOMOTION_SYNC_MODE}
ISAACLAB_G1_2_ROOT_MOTION_MODE=${ISAACLAB_G1_ROOT_MOTION_MODE}
ISAACLAB_G1_2_ROOT_ZMQ_REQUIRED=${ISAACLAB_G1_ROOT_ZMQ_REQUIRED}
ISAACLAB_G1_2_ROOT_POSITION_MODE=${ISAACLAB_G1_ROOT_POSITION_MODE}
ISAACLAB_G1_2_WRITE_ROOT_STATE=${ISAACLAB_G1_WRITE_ROOT_STATE}
ISAACLAB_G1_2_WRITE_BODY_JOINT_STATE=${ISAACLAB_G1_WRITE_BODY_JOINT_STATE}
ISAACLAB_G1_2_BODY_STATE_WRITE_JOINT_NAMES=${ISAACLAB_G1_BODY_STATE_WRITE_JOINT_NAMES}
ISAACLAB_G1_2_WRITE_HAND_JOINT_STATE=${ISAACLAB_G1_WRITE_HAND_JOINT_STATE}
ISAACLAB_G1_2_USE_SOURCE_JOINT_VELOCITY=${ISAACLAB_G1_USE_SOURCE_JOINT_VELOCITY}
ISAACLAB_G1_2_MIRROR_HANDS=${ISAACLAB_G1_MIRROR_HANDS}
ISAACLAB_G1_2_CONTROLLER_GRIPPER_ENABLED=${ISAACLAB_G1_CONTROLLER_GRIPPER_ENABLED}
ISAACLAB_G1_2_GROUND_LOCK=${ISAACLAB_G1_GROUND_LOCK}
ISAACLAB_G1_2_HOLD_DEFAULT_UNTIL_FIRST_PACKET=${ISAACLAB_G1_HOLD_DEFAULT_UNTIL_FIRST_PACKET}
ISAACLAB_G1_2_NO_PACKET_DEBUG_INTERVAL_S=${ISAACLAB_G1_NO_PACKET_DEBUG_INTERVAL_S}
ISAACLAB_G1_2_BODY_JOINT_TARGET_MAX_DELTA=${ISAACLAB_G1_BODY_JOINT_TARGET_MAX_DELTA}
ISAACLAB_G1_2_ZERO_TARGET_ONLY_BODY_VELOCITY=${ISAACLAB_G1_ZERO_TARGET_ONLY_BODY_VELOCITY}
ISAACLAB_G1_2_ZERO_TARGET_ONLY_HAND_VELOCITY=${ISAACLAB_G1_ZERO_TARGET_ONLY_HAND_VELOCITY}
ISAACLAB_G1_2_BODY_JOINT_TARGET_SCALE_OVERRIDES=${ISAACLAB_G1_BODY_JOINT_TARGET_SCALE_OVERRIDES}
ISAACLAB_G1_2_HAND_JOINT_TARGET_MAX_DELTA=${ISAACLAB_G1_HAND_JOINT_TARGET_MAX_DELTA}

# OpenXR trigger/grip gripper control. OpenXR input is kept as a command; Isaac
# Lab applies the resulting hand pose through joint targets. Leave direct state
# writes disabled for physical grasping/contact tuning.
ISAACLAB_G1_GRIPPER_TRANSPORT=zmq
ISAACLAB_G1_GRIPPER_FINGER_CLOSE_ANGLE=1.8
ISAACLAB_G1_GRIPPER_THUMB_YAW_ANGLE=0.5
ISAACLAB_G1_GRIPPER_THUMB_1_ANGLE=1.1
ISAACLAB_G1_GRIPPER_THUMB_2_ANGLE=1.8
ISAACLAB_G1_GRIPPER_ACTION_ALPHA=0.75
ISAACLAB_G1_GRIPPER_USE_SOFT_LIMITS=0
ISAACLAB_G1_GRIPPER_WRITE_JOINT_STATE=0
ISAACLAB_G1_GRIPPER_TARGET_MAX_DELTA=0.03
ISAACLAB_G1_GRIPPER_PUBLISH_INTERVAL_S=0.0
ISAACLAB_G1_GRIPPER_DEBUG_INTERVAL_S=0.0

# ID-scoped UDP receivers. Legacy single-robot aliases remain below.
ISAACLAB_G1_1_UDP_BIND_HOST=0.0.0.0
ISAACLAB_G1_1_UDP_PORT=5557
ISAACLAB_G1_1_UDP_TOPIC=g1_1_debug
ISAACLAB_G1_1_UDP_RCVBUF=262144
ISAACLAB_G1_1_ROOT_UDP_BIND_HOST=0.0.0.0
ISAACLAB_G1_1_ROOT_UDP_PORT=5558
ISAACLAB_G1_1_ROOT_UDP_TOPIC=g1_1_root
ISAACLAB_G1_1_ROOT_UDP_RCVBUF=262144

ISAACLAB_G1_2_UDP_BIND_HOST=0.0.0.0
ISAACLAB_G1_2_UDP_PORT=5567
ISAACLAB_G1_2_UDP_TOPIC=g1_2_debug
ISAACLAB_G1_2_UDP_RCVBUF=262144
ISAACLAB_G1_2_ROOT_UDP_BIND_HOST=0.0.0.0
ISAACLAB_G1_2_ROOT_UDP_PORT=5568
ISAACLAB_G1_2_ROOT_UDP_TOPIC=g1_2_root
ISAACLAB_G1_2_ROOT_UDP_RCVBUF=262144

# Legacy/single-robot UDP aliases.
ISAACLAB_G1_UDP_BIND_HOST=0.0.0.0
ISAACLAB_G1_UDP_PORT=5557
ISAACLAB_G1_UDP_TOPIC=g1_debug
ISAACLAB_G1_UDP_RCVBUF=262144
ISAACLAB_G1_ROOT_UDP_BIND_HOST=0.0.0.0
ISAACLAB_G1_ROOT_UDP_PORT=5558
ISAACLAB_G1_ROOT_UDP_TOPIC=g1_root
ISAACLAB_G1_ROOT_UDP_RCVBUF=262144

# ---------------------------------------------------------------------------
# Ubuntu sender values are kept here for reference.
# Isaac Lab does not send these packets, but keeping both sides in one file
# makes IP changes easier to audit.
# ---------------------------------------------------------------------------
G1_LOCAL_ROBOT_ID=1
G1_OUTPUT_TYPE=udp
G1_1_ZMQ_OUT_PORT=5557
G1_1_ZMQ_OUT_TOPIC=g1_1_debug
G1_2_ZMQ_OUT_PORT=5567
G1_2_ZMQ_OUT_TOPIC=g1_2_debug
G1_ZMQ_OUT_PORT=5557
G1_ZMQ_OUT_TOPIC=g1_debug
G1_1_UDP_OUT_BIND_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
G1_1_UDP_OUT_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
G1_1_UDP_OUT_HOSTS=${WINDOWS_ROBOT_1_ISAACLAB_IP},${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_1_UDP_OUT_PORT=5557
G1_1_UDP_OUT_TOPIC=g1_1_debug
G1_2_UDP_OUT_BIND_HOST=${UBUNTU_ROBOT_2_SENDER_IP}
G1_2_UDP_OUT_HOST=${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_2_UDP_OUT_HOSTS=${WINDOWS_ROBOT_1_ISAACLAB_IP},${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_2_UDP_OUT_PORT=5567
G1_2_UDP_OUT_TOPIC=g1_2_debug
G1_UDP_OUT_BIND_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
G1_UDP_OUT_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
G1_UDP_OUT_HOSTS=${WINDOWS_ROBOT_1_ISAACLAB_IP},${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_UDP_OUT_PORT=5557
G1_UDP_OUT_TOPIC=g1_debug
G1_1_ROOT_ZMQ_PORT=5558
G1_1_ROOT_ZMQ_TOPIC=g1_1_root
G1_1_ROOT_ZMQ_ENABLE=0
G1_2_ROOT_ZMQ_PORT=5568
G1_2_ROOT_ZMQ_TOPIC=g1_2_root
G1_2_ROOT_ZMQ_ENABLE=0
G1_ROOT_ZMQ_PORT=5558
G1_ROOT_ZMQ_TOPIC=g1_root
G1_ROOT_ZMQ_ENABLE=0
G1_1_ROOT_UDP_BIND_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
G1_1_ROOT_UDP_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
G1_1_ROOT_UDP_HOSTS=${WINDOWS_ROBOT_1_ISAACLAB_IP},${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_1_ROOT_UDP_PORT=5558
G1_1_ROOT_UDP_TOPIC=g1_1_root
G1_1_ROOT_UDP_ENABLE=1
G1_2_ROOT_UDP_BIND_HOST=${UBUNTU_ROBOT_2_SENDER_IP}
G1_2_ROOT_UDP_HOST=${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_2_ROOT_UDP_HOSTS=${WINDOWS_ROBOT_1_ISAACLAB_IP},${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_2_ROOT_UDP_PORT=5568
G1_2_ROOT_UDP_TOPIC=g1_2_root
G1_2_ROOT_UDP_ENABLE=1
G1_ROOT_UDP_BIND_HOST=${UBUNTU_ROBOT_1_SENDER_IP}
G1_ROOT_UDP_HOST=${WINDOWS_ROBOT_1_ISAACLAB_IP}
G1_ROOT_UDP_HOSTS=${WINDOWS_ROBOT_1_ISAACLAB_IP},${WINDOWS_ROBOT_2_ISAACLAB_IP}
G1_ROOT_UDP_PORT=5558
G1_ROOT_UDP_TOPIC=g1_root
G1_ROOT_UDP_ENABLE=1
